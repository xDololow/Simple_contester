MARIADB_DATABASE=simple_contester
MARIADB_USER=contestant
MARIADB_PASSWORD=contestant
MARIADB_ROOT_PASSWORD=root
MARIADB_PORT=3307

BACKEND_PORT=8001
FRONTEND_PORT=5173
VITE_API_BASE=http://localhost:8001
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=mysql+pymysql://contestant:contestant@mariadb:3306/simple_contester
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=1440
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

JUDGER_ID=docker-judger
POLL_INTERVAL_SECONDS=1
STOP_ON_FIRST_FAILED_TEST=1
