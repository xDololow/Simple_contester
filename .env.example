# Copy to .env and replace every demo secret before production use.

# MariaDB. DATABASE_URL is used by backend and judger inside Docker.
MARIADB_DATABASE=simple_contester
MARIADB_USER=contestant
MARIADB_PASSWORD=contestant
MARIADB_ROOT_PASSWORD=root
MARIADB_PORT=3307
DATABASE_URL=mysql+pymysql://contestant:contestant@mariadb:3306/simple_contester

# Host ports and browser-facing URLs.
BACKEND_PORT=8001
FRONTEND_PORT=5173
VITE_API_BASE=http://localhost:8001
CORS_ORIGINS=http://localhost:5173

# Backend auth/bootstrap. Change JWT_SECRET and admin password in production.
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300

# Judger identity, queue polling, and submission lease behavior.
JUDGER_ID=docker-judger
JUDGER_VERSION=local
POLL_INTERVAL_SECONDS=1
JUDGER_HEARTBEAT_INTERVAL_SECONDS=5
SUBMISSION_LEASE_SECONDS=60
SUBMISSION_MAX_ATTEMPTS=3
STOP_ON_FIRST_FAILED_TEST=1

# Judger sandbox mode.
# subprocess: compatible default, no per-submission network namespace.
# docker: use docker compose --profile docker-sandbox and set DOCKER_SOCK_GID.
JUDGER_SANDBOX_MODE=subprocess
JUDGER_WORK_ROOT=/tmp/simple-contester-judger-work
JUDGER_DOCKER_IMAGE=simple-contester-judger:local
JUDGER_DOCKER_USER=judge
JUDGER_DOCKER_CPUS=1
JUDGER_DOCKER_TMPFS_SIZE=512m
DOCKER_SOCK_GID=0

# Judger resource limits.
OUTPUT_LIMIT_BYTES=1048576
PROCESS_LIMIT=256
FILE_SIZE_LIMIT_BYTES=16777216
COMPILE_TIMEOUT_SECONDS=20
COMPILE_MEMORY_LIMIT_MB=4096
COMPILE_PROCESS_LIMIT=256
COMPILE_FILE_SIZE_LIMIT_BYTES=268435456

# Backup/restore scripts.
BACKUP_DIR=backups
MARIADB_SERVICE=mariadb
BACKUP_DB_USER=root
BACKUP_DB_PASSWORD=root
RESTORE_DB_USER=root
RESTORE_DB_PASSWORD=root
# RESTORE_YES=1
